<%- include('../layouts/header', { title: 'Create airplane' }) %>

  <h2>Create Airplane</h2>

  <div id="errorBox"></div>

  <form id="flightForm">
    <input type="text" class="form-control mb-2" name="modelNumber" id="modelNumber" placeholder="Model Number">
    <input type="number" class="form-control mb-2" id="capacity" name="capacity" placeholder="Capacity">
    <div class="mb-3">
      <label for="formFile" class="form-label">Default file input example</label>
      <input class="form-control" type="file" name="airplane_image" id="formFile">
    </div>

    <button class="btn btn-primary">Submit</button>
  </form>

  <div id="imagePreview" class="mt-3"></div>

  <%- include('../layouts/footer') %>

    <script src="/js/airplane.js"></script>